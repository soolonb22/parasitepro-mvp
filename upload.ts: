// app/actions/upload.ts
'use server';

import { Anthropic } from '@anthropic-ai/sdk';
import cloudinary from 'cloudinary';
import { redirect } from 'next/navigation';

cloudinary.v2.config({
  cloud_name: process.env.CLOUDINARY_CLOUD_NAME!,
  api_key: process.env.CLOUDINARY_API_KEY!,
  api_secret: process.env.CLOUDINARY_API_SECRET!,
});

const anthropic = new Anthropic({
  apiKey: process.env.ANTHROPIC_API_KEY!,
});

export async function uploadAndAnalyze(formData: FormData) {
  const file = formData.get('photo') as File | null;
  if (!file) {
    throw new Error('Please select a photo');
  }

  // Security: basic size & type check (add more if needed)
  if (file.size > 5 * 1024 * 1024) throw new Error('Photo too large — max 5MB');
  if (!file.type.startsWith('image/')) throw new Error('Only images allowed');

  // 1. Upload to Cloudinary (temporary)
  const bytes = await file.arrayBuffer();
  const buffer = Buffer.from(bytes);
  const uploadResult = await cloudinary.v2.uploader.upload(
    `data:${file.type};base64,${buffer.toString('base64')}`,
    { folder: 'parasite-pro-analyses' }
  );

  // 2. Send to Claude (vision model) — strict educational prompt
  const base64Image = buffer.toString('base64');
  const message = await anthropic.messages.create({
    model: 'claude-3-5-sonnet-20241022', // update to latest 2026 model if available
    max_tokens: 1000,
    temperature: 0.2,
    system: "You are PARA, a friendly educational AI guide for Australians. Analyse ONLY visual patterns in the photo. Never diagnose, treat, or give medical advice. Always flag urgency as Low / Moderate / High. End every response with: 'Educational tool only — not a medical diagnosis. See your GP.'",
    messages: [
      {
        role: 'user',
        content: [
          { type: 'text', text: 'Analyse this photo for educational purposes. Describe visible patterns, flag urgency level, and list things worth mentioning to a GP. Keep it calm and helpful for QLD families, travellers, or pet owners.' },
          { type: 'image', source: { type: 'base64', media_type: file.type as any, data: base64Image } }
        ]
      }
    ]
  });

  const reportText = (message.content[0] as any).text;

  // For now, pass report via URL params (later we'll use DB)
  const encodedReport = encodeURIComponent(JSON.stringify({
    text: reportText,
    urgency: 'Moderate', // parse from Claude in future
    imageUrl: uploadResult.secure_url,
    date: new Date().toISOString()
  }));

  redirect(`/report?data=${encodedReport}`);
}
