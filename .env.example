# ─── ParasitePro Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# ── Auth (NextAuth v5) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-32-char-random-secret-here
NEXTAUTH_URL=https://notworms.com

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database (PostgreSQL via Railway) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/parasitepro

# Run these SQL migrations once in your Railway Postgres console:
# See lib/db.ts for full schema.

# ── Stripe ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_BUNDLE_5=price_...
NEXT_PUBLIC_STRIPE_PRICE_BUNDLE_10=price_...
NEXT_PUBLIC_STRIPE_PRICE_BUNDLE_25=price_...

# ── Cloudinary ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://notworms.com

# ── Email (optional — for waitlist notifications) ──────────────────────────────
RESEND_API_KEY=re_...
RESEND_WAITLIST_AUDIENCE_ID=aud_...
